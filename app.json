{
  "expo": {
    "name": "CarApp",
    "slug": "CarApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "carapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.san1t.CarApp",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos usar tu cámara para fotografiar tu licencia de conducción.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para guardar imágenes de tu licencia.",
        "NSPhotoLibraryAddUsageDescription": "Necesitamos guardar fotos de tu licencia en tu galería.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.san1t.CarApp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tus fotos para guardar imágenes de tu licencia.",
          "cameraPermission": "Necesitamos usar tu cámara para fotografiar tu licencia de conducción."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8e4d4d9c-e842-4bf2-ad6c-edf2a806dda6"
      }
    }
  }
}
